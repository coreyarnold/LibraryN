# Copy this file to .env and fill in your values

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# First admin account (created automatically on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_DISPLAY_NAME=Admin

# Cover image storage (defaults to instance/covers; use /data/covers for Docker)
COVERS_DIR=/data/covers

# Optional: OMDb API key for richer DVD metadata (https://www.omdbapi.com/apikey.aspx)
# OMDB_API_KEY=

# MySQL only (ignored for SQLite)
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_DATABASE=library
MYSQL_USER=librarian
MYSQL_PASSWORD=library_pass
